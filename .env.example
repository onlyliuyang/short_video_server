# MiniMax API
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com
MINIMAX_LLM_MODEL=MiniMax-M2.5
MINIMAX_VIDEO_MODEL=MiniMax-Hailuo-2.3
MINIMAX_TTS_MODEL=speech-02-hd
MINIMAX_TTS_VOICE_ID=Chinese (Mandarin)_Reliable_Executive

# Database
DATABASE_URL=postgresql+asyncpg://shortvideo:shortvideo@localhost:5432/shortvideo
DATABASE_URL_SYNC=postgresql+psycopg://shortvideo:shortvideo@localhost:5432/shortvideo

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Storage
STORAGE_PATH=./storage
STORAGE_PUBLIC_URL=http://localhost:8000/media

# 生成模式：image（文生图+FFmpeg，默认）| video（海螺视频，付费开启）
GENERATION_MODE=image
MINIMAX_IMAGE_MODEL=image-01
IMAGE_ASPECT_RATIO=16:9
IMAGE_CONCURRENCY=5

# === Multi-provider defaults ===
DEFAULT_GENERATION_MODE=image
DEFAULT_LLM_PROVIDER=minimax_llm
DEFAULT_TTS_PROVIDER=minimax_tts
ENABLED_LLM_PROVIDERS=minimax_llm
ENABLED_TTS_PROVIDERS=minimax_tts
ENABLED_IMAGE_PROVIDERS=minimax_image
ENABLED_VIDEO_PROVIDERS=minimax_hailuo
PROMPT_HOT_RELOAD=false

# Video settings
SEGMENT_COUNT=4
SEGMENT_DURATION_SEC=6
VIDEO_RESOLUTION=1080P
VIDEO_CONCURRENCY=3
# 段间 dissolve 转场（秒），0=硬切；类型见 ffmpeg xfade（fade/dissolve/wipeleft 等）
SEGMENT_TRANSITION_SEC=0.4
SEGMENT_TRANSITION_TYPE=fade
MINIMAX_PROMPT_OPTIMIZER=false

# FFmpeg (macOS Homebrew 默认路径)
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
# FFMPEG_PATH=/opt/homebrew/bin/ffmpeg
# FFPROBE_PATH=/opt/homebrew/bin/ffprobe

# App
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_HOST=0.0.0.0
API_PORT=8000
